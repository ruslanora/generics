{
    "name": "ruslanora/generics",
    "description": "Type-safe collections for PHP, powered by PHPStan generics.",
    "version": "1.0.0",
    "type": "library",
    "keywords": [],
    "homepage": "https://github.com/ruslanora/generics",
    "readme": "README.md",
    "license": "MIT",
    "authors": [
        {
            "name": "Ruslan Ora",
            "email": "ruslan.ora@outlook.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ruslanora/generics/issues",
        "wiki": "https://github.com/ruslanora/generics/wiki",
        "security": "https://github.com/ruslanora/generics/security/advisories"
    },
    "funding": [
        {
            "type": "buymeacoffee",
            "url": "https://buymeacoffee.com/ruslanora"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.95.13",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "Ruslan\\Generics\\": "src/Generics/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruslan\\Generics\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": "php-cs-fixer fix",
        "format:check": "php-cs-fixer fix --dry-run --diff",
        "analyse": "phpstan analyse",
        "test": "phpunit"
    }
}
